// Approach - Prefix Maximum + Suffix Minimum Technique
// T.C - O(n)
// S.C - O(n)


class Solution {
    public int[] maxValue(int[] nums) {

        // Length of the input array
        int n = nums.length;

        // Array to store final answers
        int[] ans = new int[n];

        // Prefix maximum array
        // preMax[i] stores maximum element from index 0 to i
        int[] preMax = new int[n];

        // Initialize first element
        preMax[0] = nums[0];

        // Build prefix maximum array
        for(int i = 1; i < n; i++){
            preMax[i] = Math.max(nums[i], preMax[i - 1]);
        }

        // Suffix minimum array
        // suffMin[i] stores minimum element from index i to n-1
        int[] suffMin = new int[n];

        // Initialize last element
        suffMin[n - 1] = nums[n - 1];

        // Build suffix minimum array
        for(int i = n - 2; i >= 0; i--){
            suffMin[i] = Math.min(nums[i], suffMin[i + 1]);
        }

        // Last answer will always be the overall prefix maximum
        ans[n - 1] = preMax[n - 1];

        // Traverse from right to left
        for(int i = n - 2; i >= 0; i--){

            // If left side maximum is greater than
            // the minimum element on the right side,
            // propagate the next answer
            if(preMax[i] > suffMin[i + 1]){
                ans[i] = ans[i + 1];
            }

            // Otherwise current prefix maximum is valid
            else{
                ans[i] = preMax[i];
            }
        }

        // Return final answer array
        return ans;
    }
}
