// Approach 1 : Linear Scan / One Pass Traversal
// T . C- O(n)
// S . C - O(1)

class Solution {
    public boolean checkOnesSegment(String s) {

        int count = 0;          // counts number of segments of '1'
        int n = s.length();     // length of string
        int i = 0;              // pointer to traverse the string

        // traverse the string
        while(i < n){

            // if current character is '1', a segment of 1's starts
            if(s.charAt(i) == '1'){
                count++;        // increase segment count

                // move forward while characters are '1'
                // this skips the whole continuous segment of '1'
                while(i < n && s.charAt(i) == '1'){
                    i++;
                }
            }
            else{
                // if character is '0', just move to next index
                i++;
            }

            // if more than one segment of '1' is found, return false
            if(count > 1) return false;
        }

        // if at most one segment exists, return true
        return true;
    }
}


// Approach 2 : Single Pass Traversal / String Scanning
// T . C- O(n)
// S . C - O(1)


class Solution {
    public boolean checkOnesSegment(String s) {

        int i = 0;

        // Traverse the string and check adjacent characters
        while(i + 1 < s.length()) {

            // If we find pattern "01"
            // It means a new segment of '1' is starting after '0'
            // So there are more than one segment of '1's
            if(s.charAt(i) == '0' && s.charAt(i + 1) == '1') {
                return false;
            }

            // Move to next index
            i++;
        }

        // If "01" never appears, then there is at most one segment of '1'
        return true;
    }
}


