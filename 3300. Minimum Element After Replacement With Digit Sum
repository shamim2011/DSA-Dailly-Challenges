// Approach - Digit Sum Transformation + Linear Scan
// T.C - O(n * d),         n = number of elements,         d = number of digits in each number
// S.C - O(1)


class Solution {
    public int minElement(int[] nums) {
        int n = nums.length; // Get size of array
        
        int ans = Integer.MAX_VALUE; // Initialize answer with maximum possible integer
        
        // Traverse each element of the array
        for(int i = 0; i < n; i++){
            int elem = nums[i]; // Store current element
            
            // Replace current element with its digit sum
            nums[i] = digitSum(elem);
            
            // Update the minimum value found so far
            ans = Math.min(ans, nums[i]);
        }
        
        return ans; // Return the minimum digit sum
    }

    // Function to calculate sum of digits of a number
    int digitSum(int d){
        int sum = 0;
        
        // Extract digits and add them
        while(d > 0){
            sum += (d % 10); // Get last digit
            d = d / 10;      // Remove last digit
        }
        
        return sum; // Return digit sum
    }
}
