// Approach - Digit Transformation + Iterative Digit Sum (Simulation)
// T.C - O(n + k)
// S.C - O(1)


class Solution {
    public int getLucky(String s, int k) {
        int sum = 0;

        // Step 1: Convert each character to its position (a=1, b=2, ..., z=26)
        // and add the digits of that number to sum
        for(int i = 0; i < s.length(); i++){
            int val = s.charAt(i) - 'a' + 1; // get position of character

            // add digits of val to sum
            while(val > 0){
                sum += val % 10;
                val = val / 10;
            }
        }

        // Step 2: Repeat digit sum transformation (k-1 times)
        for(int i = 1; i < k; i++){
            int newSum = 0;

            // If sum is already single digit, return it early
            if(sum <= 9) return sum;

            // compute sum of digits again
            while (sum > 0) {
                newSum += sum % 10;
                sum /= 10;
            }

            sum = newSum; // update sum for next iteration
        }

        return sum; // final result
    }
}
