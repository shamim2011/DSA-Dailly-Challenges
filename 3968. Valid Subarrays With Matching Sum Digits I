// Approach 1 - Brute Force - Check All Subarrays
// T.C - O(n² · d)
// S.C - O(d)



class Solution {
    public int countValidSubarrays(int[] nums, int x) {
        int ans = 0;

        // Iterate through every possible starting index
        for (int i = 0; i < nums.length; i++) {
            long sum = 0;

            // Extend the subarray from index i to every possible ending index
            for (int j = i; j < nums.length; j++) {
                sum += nums[j];

                // Check if the current subarray sum is valid
                if (isValid(sum, x)) {
                    ans++;
                }
            }
        }

        return ans;
    }

    boolean isValid(long sum, int x) {
        // Convert sum to string to access first and last digits
        String s = Long.toString(sum);

        // Extract first digit
        int f = s.charAt(0) - '0';

        // Extract last digit
        int l = s.charAt(s.length() - 1) - '0';

        // Valid if both first and last digits are equal to x
        return (f == x && l == x);
    }
}
