// Approach - Manhattan Distance + Flexible Move Counting
// T.C - O(n)
// S.C - O(1)



class Solution {
    public int maxDistance(String moves) {
        // Final x and y coordinates
        int x1 = 0;
        int y1 = 0;

        // Count of unspecified/flexible moves
        int k = 0;

        // Traverse each move in the string
        for (char ch : moves.toCharArray()) {

            if (ch == 'U') {
                // Move one step up
                x1 = x1;
                y1 = y1 + 1;
            }
            else if (ch == 'D') {
                // Move one step down
                x1 = x1;
                y1 = y1 - 1;
            }
            else if (ch == 'L') {
                // Move one step left
                x1 = x1 - 1;
                y1 = y1;
            }
            else if (ch == 'R') {
                // Move one step right
                x1 = x1 + 1;
                y1 = y1;
            }
            else {
                // Count flexible/unknown moves
                k++;
            }
        }

        // Manhattan distance from origin
        // plus contribution of all flexible moves
        return Math.abs(0 - x1) + Math.abs(0 - y1) + k;
    }
}
