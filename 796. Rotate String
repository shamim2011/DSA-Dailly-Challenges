// Approach 1 - (Brute Force Check all rotations)
// T.C - O(n^2)
// S.C - O(1)


class Solution {
    public boolean rotateString(String s, String goal) {
        int m = s.length();   // length of string s
        int n = goal.length(); // length of string goal

        // If lengths are not equal, rotation is not possible
        if(m != n) return false;

        // Try all possible rotations
        for(int i = 1; i <= m; i++){
            // Rotate string by moving first character to the end
            s = s.substring(1) + s.charAt(0);

            // Check if rotated string matches goal
            if(s.equals(goal)){
                return true;
            }
        }

        // If no rotation matches
        return false;
    }
}



// Approach 2 - (Concatenation with itself contains all possible rotations)
// T.C - O(n)
// S.C - O(1)


class Solution {
    public boolean rotateString(String s, String goal) {
        int m = s.length();     // Length of string s
        int n = goal.length();  // Length of string goal

        // Check:
        // 1. Lengths must be equal
        // 2. goal should be a substring of (s + s)
        // If both conditions are true, rotation is possible
        if (m == n && (s + s).contains(goal)) return true;

        // Otherwise, rotation is not possible
        return false;
    }
}
