// Approach - Top-Down Dynamic Programming (Memoization) with State (i, j, remaining skips)
// T.C - O(m * n * 3)  ≈  O(m * n)
// S.C - O(m * n * 3) + O(m + n recursion stack)


class Solution {
    int m;
    int n;
    int[][][] dp;

    // Recursive function with memoization
    int solve(int[][] coins, int i, int j, int neu) {

        // Out of bounds → invalid path
        if (i >= m || j >= n) return Integer.MIN_VALUE;

        // Base case: reached bottom-right cell
        if (i == m - 1 && j == n - 1) {

            // If negative and we can skip → skip it (take 0)
            if (coins[i][j] < 0 && neu > 0) {
                return 0;
            }

            // Otherwise take the value
            return coins[i][j];
        }

        // If already computed → return memoized result
        if (dp[i][j][neu] != Integer.MIN_VALUE) {
            return dp[i][j][neu];
        }

        int best = Integer.MIN_VALUE;

        // Move Down
        int down = solve(coins, i + 1, j, neu);
        if (down != Integer.MIN_VALUE) {
            best = Math.max(best, coins[i][j] + down);
        }

        // Move Right
        int right = solve(coins, i, j + 1, neu);
        if (right != Integer.MIN_VALUE) {
            best = Math.max(best, coins[i][j] + right);
        }

        // Skip current cell (only if negative and skips available)
        if (coins[i][j] < 0 && neu > 0) {

            // Try skipping and moving
            int downSkip = solve(coins, i + 1, j, neu - 1);
            int rightSkip = solve(coins, i, j + 1, neu - 1);

            int bestSkip = Math.max(downSkip, rightSkip);

            // Update best if skip path is valid
            if (bestSkip != Integer.MIN_VALUE) {
                best = Math.max(bestSkip, best);
            }
        }

        // Store result in DP and return
        return dp[i][j][neu] = best;
    }

    public int maximumAmount(int[][] coins) {

        m = coins.length;
        n = coins[0].length;

        // 3D DP: position (i,j) + remaining skips (neu)
        dp = new int[m][n][3];

        // Initialize DP with MIN_VALUE
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                for (int k = 0; k < 3; k++) {
                    dp[i][j][k] = Integer.MIN_VALUE;
                }
            }
        }

        // Start from (0,0) with 2 skips available
        return solve(coins, 0, 0, 2);
    }
}
