// Approach 1 - Frequency Counting + Sorted Map (TreeMap Traversal)
// T.C  - O(n log n)
// S.C - O(n)


class Solution {
    public int[] limitOccurrences(int[] nums, int k) {
        
        // List to store final result
        List<Integer> li = new ArrayList<>();
        
        // TreeMap to store frequency of each number (sorted order)
        TreeMap<Integer,Integer> mp = new TreeMap<>();
        
        // Step 1: Count frequency of each element
        for(int i = 0; i < nums.length; i++){
            mp.put(nums[i], mp.getOrDefault(nums[i], 0) + 1);
        }
        
        // Step 2: Traverse map (sorted keys) and add elements up to k times
        for(Map.Entry<Integer,Integer> entry : mp.entrySet()){
            int key = entry.getKey();   // number
            int val = entry.getValue(); // frequency
            
            // Add the number min(k, frequency) times
            for(int i = 0; i < k && i < val; i++){
                li.add(key);
            }
        }
        
        // Step 3: Convert list to array
        int[] ans = new int[li.size()];
        int i = 0;
        
        // (Optional reverse was commented out)
        // Collections.reverse(li);
        
        for(int num : li){
            ans[i++] = num;
        }
        
        // Return final array
        return ans;
    }
}



// Approach 2 - Hashing + Greedy Filtering (Frequency Control)
// T.C  - O(n)
// S.C - O(n)


class Solution {
    public int[] limitOccurrences(int[] nums, int k) {
        
        // List to store the final filtered elements
        List<Integer> li = new ArrayList<>();
        
        // HashMap to store frequency of each number
        Map<Integer,Integer> mp = new HashMap<>();
        
        // Traverse each element in the array
        for(int num : nums){
            
            // Get current count of the number (default = 0)
            int count = mp.getOrDefault(num,0);
            
            // Only allow the number if its count is less than k
            if(count < k){
                li.add(num);              // Add to result list
                mp.put(num, count + 1);  // Update frequency in map
            }
        }
        
        // Convert List to Array
        int[] ans = new int[li.size()];
        int i = 0;
        
        // Optional reverse (currently commented out)
        // Collections.reverse(li);
        
        // Copy elements from list to array
        for(int num : li){
            ans[i++] = num;
        }
        
        // Return final array
        return ans;
    }
}
