// Approach 1 - Greedy + Sorting
// T.C - O(n log n)
// S.C - O(1)



class Solution {
    public int maxIceCream(int[] costs, int coins) {
        
        // Sort the costs in ascending order
        Arrays.sort(costs);

        // Stores the number of ice creams bought
        int ans = 0;

        // Traverse through the sorted costs array
        for (int i = 0; i < costs.length; i++) {

            // If remaining coins are less than current cost,
            // we cannot buy any more ice creams
            if (coins < costs[i]) {
                return ans;
            } 
            else {
                // Buy the current ice cream
                ans++;

                // Deduct its cost from available coins
                coins -= costs[i];
            }
        }

        // Return total ice creams bought
        return ans;
    }
}



//Approach-2 (Counting Sorting and greedily choosing)
//T.C : O(maxCost)
//S.C : O(1) (ignoring the space taken for sorting internally)
class Solution {
    public int maxIceCream(int[] costs, int coins) {
        int maxCost = 0;
        for (int cost : costs)
            maxCost = Math.max(maxCost, cost);
        
        // count[c] = how many ice creams cost exactly c
        int[] count = new int[maxCost + 1];
        for (int cost : costs)
            count[cost]++;
        
        int total = 0;
        for (int cost = 1; cost <= maxCost; cost++) {
            if (count[cost] == 0)
                continue;
            
            if (coins < cost)
                break;
            
            // Jitna possible hai buy kar lo
            int buy_kiya = Math.min(count[cost], coins / cost);
            total += buy_kiya;
            coins -= (long) buy_kiya * cost > coins ? 0 : buy_kiya * cost;
        }
        
        return total;
    }
}
