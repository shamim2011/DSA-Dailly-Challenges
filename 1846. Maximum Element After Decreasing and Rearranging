// Approach - Sorting + Greedy Adjustment
// T.C - O(n log n)
// S.C - O(1)



class Solution {
    public int maximumElementAfterDecrementingAndRearranging(int[] arr) {

        // Sort the array so that we can process elements in increasing order
        Arrays.sort(arr);

        int n = arr.length;

        // The maximum possible value after modifications
        int maxE = 1;

        // Traverse the sorted array
        for (int i = 0; i < n; i++) {

            // First element must always be 1
            if (i == 0) {
                arr[i] = 1;
            }

            // If the difference with previous element is greater than 1,
            // reduce the current element to previous + 1
            else if (arr[i] - arr[i - 1] > 1) {
                arr[i] = arr[i - 1] + 1;
            }

            // Keep track of the maximum element
            maxE = Math.max(maxE, arr[i]);
        }

        // Return the maximum possible element
        return maxE;
    }
}
