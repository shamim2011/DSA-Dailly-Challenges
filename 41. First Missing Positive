// Approach 1 - Sorting + Remove Duplicates + Linear Scan
// T.C - O(n log n)
// S.C - O(m)



class Solution {
    public int firstMissingPositive(int[] nums) {
        int n = nums.length;

        // Sort the array
        Arrays.sort(nums);

        // List to store unique positive numbers
        List<Integer> li = new ArrayList<>();

        // Traverse the sorted array
        for (int i = 0; i < n; i++) {

            // Ignore non-positive numbers
            if (nums[i] <= 0)
                continue;

            // Add only unique positive numbers
            else if (li.isEmpty() || li.get(li.size() - 1) != nums[i]) {
                li.add(nums[i]);
            }
        }

        // Find the first missing positive
        for (int i = 0; i < li.size(); i++) {
            if (i + 1 != li.get(i)) {
                return (i + 1);
            }
        }

        // If all positives from 1 to size exist,
        // then answer is the next positive number
        return li.size() + 1;
    }
}




// Approach 2 - HashSet Approach
// T.C - O(n)
// S.C - O(n)



class Solution {
    public int firstMissingPositive(int[] nums) {

        // Create a HashSet to store all positive numbers
        Set<Integer> hs = new HashSet<>();

        // Traverse the array
        for (int x : nums) {

            // Store only positive numbers in the HashSet
            if (x > 0) {
                hs.add(x);
            }
        }

        // Start checking from the smallest positive integer
        int miss = 1;

        // Keep incrementing until a missing positive number is found
        while (hs.contains(miss)) {
            miss++;
        }

        // Return the first missing positive integer
        return miss;
    }
}
