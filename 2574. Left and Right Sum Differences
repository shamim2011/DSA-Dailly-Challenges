// Approach 1 - Simulation
// T.C - O(n)
// S.C - O(n)


class Solution {
    public int[] leftRightDifference(int[] nums) {
        int n = nums.length;
        int[] ans = new int[n];
        int[] left = new int[n];
        int[] right = new int[n];
        int lsum = 0;
        for(int i=0;i<n;i++){
            left[i] = lsum;
            lsum += nums[i];
        }
        int rsum = 0;
        for(int i=n-1;i>=0;i--){
            right[i] = rsum;
            rsum += nums[i];
        }
        for(int i=0;i<n;i++){
            ans[i] = Math.abs(left[i]-right[i]);
        }
        return ans;
    }
}



// Approach 2 - Prefix Sum / Running Left & Right Sum
// T.C - O(n)
// S.C - O(1)



class Solution {
    public int[] leftRightDifference(int[] nums) {
        int n = nums.length;

        // Array to store the final answer
        int[] ans = new int[n];

        // Calculate total sum of all elements
        int sum = 0;
        for (int num : nums) {
            sum += num;
        }

        // Stores the sum of elements on the left side of current index
        int leftSum = 0;

        // Traverse the array
        for (int i = 0; i < n; i++) {

            // Remove current element from total sum
            // Remaining sum becomes the right sum
            sum -= nums[i];

            // Store absolute difference between left sum and right sum
            ans[i] = Math.abs(leftSum - sum);

            // Add current element to left sum for next iteration
            leftSum += nums[i];
        }

        return ans;
    }
}
