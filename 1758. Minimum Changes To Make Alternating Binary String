// Approach - 1 - Greedy – Two Pattern Comparison (Alternating String Check)
// T.C - O(n)
// S.C - O(1)


class Solution {
    public int minOperations(String s) {
        int n = s.length();
        
        // Count operations if string starts with '0' -> pattern "010101..."
        int start_with_0 = 0;
        
        // Count operations if string starts with '1' -> pattern "101010..."
        int start_with_1 = 0;

        for (int i = 0; i < n; i++) {
            
            // If index is even
            if (i % 2 == 0) {
                
                // For pattern starting with '0', even index should be '0'
                // If it's '1', we need one change
                if (s.charAt(i) == '0') {
                    // If it's '0', then pattern starting with '1' needs change
                    start_with_1++;
                } else {
                    // If it's '1', then pattern starting with '0' needs change
                    start_with_0++;
                }
                
            } else { // If index is odd
                
                // For pattern starting with '0', odd index should be '1'
                // If it's '0', we need one change
                if (s.charAt(i) == '1') {
                    // If it's '1', then pattern starting with '1' needs change
                    start_with_1++;
                } else {
                    // If it's '0', then pattern starting with '0' needs change
                    start_with_0++;
                }
            }
        }
        
        // Return minimum operations required
        return Math.min(start_with_0, start_with_1);
    }
}


// Approach - 2 - Pattern Matching (Two Alternating Pattern Comparison)
// T.C - O(n)
// S.C - O(1)


class Solution {
    public int minOperations(String s) {
        int n = s.length();          // Length of the string
        int start_with_1 = 0;        // Count mismatches if pattern starts with '1'

        for (int i = 0; i < n; i++) {
            
            // If index is even
            if (i % 2 == 0) {
                // In pattern starting with '1',
                // even index should contain '1'
                if (s.charAt(i) == '0') {
                    start_with_1++;  // Count mismatch
                }
            } 
            else {
                // In pattern starting with '1',
                // odd index should contain '0'
                if (s.charAt(i) == '1') {
                    start_with_1++;  // Count mismatch
                }
            }
        }

        // If mismatches for pattern starting with '1' = start_with_1
        // Then mismatches for pattern starting with '0' = n - start_with_1
        // Return minimum of both
        return Math.min(n - start_with_1, start_with_1);
    }
}
