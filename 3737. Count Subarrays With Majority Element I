// Approach 1 - Brute Force - Enumerating All Subarrays
// T.C - O(n*n)
// S.C - O(1)



class Solution {
    public int countMajoritySubarrays(int[] nums, int target) {
        int ans = 0; // Stores the count of valid subarrays

        // Iterate through all possible starting indices
        for (int i = 0; i < nums.length; i++) {

            int tarCount = 0;    // Count of target elements in current subarray
            int otherCount = 0;  // Count of non-target elements in current subarray

            // Extend the subarray from index i to j
            for (int j = i; j < nums.length; j++) {

                // Update counts based on current element
                if (nums[j] == target) {
                    tarCount++;
                } else {
                    otherCount++;
                }

                // Check if target is the majority element
                if (tarCount > otherCount) {
                    ans++;
                }
            }
        }

        return ans; // Return total number of majority subarrays
    }
}



// Approach 2 - Prefix Sum + HashMap Frequency Counting
// T.C - O(n)
// S.C - O(1)




class Solution {
    public int countMajoritySubarrays(int[] nums, int target) {
        int ans = 0;

        // Stores frequency of each prefix sum
        Map<Integer, Integer> mp = new HashMap<>();
        mp.put(0, 1);

        int cumSum = 0;

        // Number of valid starting points for current position
        int validLeftPoints = 0;

        for (int x : nums) {

            if (x == target) {

                // All previous same prefix sums create new valid subarrays
                validLeftPoints += mp.getOrDefault(cumSum, 0);

                // Treat target as +1
                cumSum++;
            } else {

                // Treat non-target as -1
                cumSum--;

                // Remove invalid starting points
                validLeftPoints -= mp.getOrDefault(cumSum, 0);
            }

            // Store current prefix sum frequency
            mp.merge(cumSum, 1, Integer::sum);

            // Add all valid subarrays ending at current index
            ans += validLeftPoints;
        }

        return ans;
    }
}
