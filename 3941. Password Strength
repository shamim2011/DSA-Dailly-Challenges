// Approach - Character Frequency Tracking with Greedy Scoring
// T.C - O(n)
// S.C - O(1)


class Solution {
    public int passwordStrength(String s) {
        
        // Track if a lowercase letter has already been counted
        boolean[] lc = new boolean[26];
        Arrays.fill(lc, true);
        
        // Track if an uppercase letter has already been counted
        boolean[] uc = new boolean[26];
        Arrays.fill(uc, true);
        
        // Track if a digit has already been counted
        boolean[] digit = new boolean[10];
        Arrays.fill(digit, true);
        
        // Set of allowed special characters
        Set<Character> st = new HashSet<>();
        st.add('!'); 
        st.add('@'); 
        st.add('#'); 
        st.add('$');
        
        int ans = 0; // Final strength score
        
        // Traverse each character in the string
        for(int i = 0; i < s.length(); i++){
            char ch = s.charAt(i);
            
            // If lowercase and not counted before
            if((ch >= 'a' && ch <= 'z') && lc[ch - 'a']){
                ans += 1;                  // Add 1 point
                lc[ch - 'a'] = false;      // Mark as counted
                continue;
            }
            // If uppercase and not counted before
            else if((ch >= 'A' && ch <= 'Z') && uc[ch - 'A']){
                ans += 2;                  // Add 2 points
                uc[ch - 'A'] = false;      // Mark as counted
                continue;
            }
            // If digit and not counted before
            else if(((ch - '0') >= 0 && (ch - '0') <= 9) && digit[ch - '0']){
                ans += 3;                  // Add 3 points
                digit[ch - '0'] = false;   // Mark as counted
                continue;
            }
            // If special character from set
            else if(st.contains(ch)){
                ans += 5;                  // Add 5 points
                st.remove(ch);             // Ensure counted only once
            }
        }
        
        return ans; // Return final strength
    }
}
