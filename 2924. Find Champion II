// Approach - Indegree Counting Approach (Graph Theory)
// T.C - O(N+E)   , Traversing edges → O(E)     Traversing nodes → O(N)
// S.C - O(N)


class Solution {
    public int findChampion(int n, int[][] edges) {

        // Array to store indegree of each team/node
        int[] ans = new int[n];

        // Traverse all directed edges
        for(int[] arr : edges){

            // u -> v means u defeats v
            int u = arr[0];
            int v = arr[1];

            // Increase indegree of v
            ans[v]++;
        }

        // Variable to store final champion
        int champ = -1;

        // Count how many nodes have indegree 0
        int count = 0;

        // Traverse all nodes
        for(int i = 0; i < n; i++){

            // Node with indegree 0 can be champion
            if(ans[i] == 0){

                champ = i;
                count++;

                // More than one node with indegree 0
                // means champion is not unique
                if(count > 1) return -1;
            }
        }

        // Return champion node
        return champ;
    }
}
