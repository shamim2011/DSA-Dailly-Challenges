// Approach - (Linear Scan - find max and min)
// T.C - O(n)
// S.C - O(1)


class Solution {
    public long maxTotalValue(int[] nums, int k) {

        // Initialize max and min with extreme values
        int max = Integer.MIN_VALUE;
        int min = Integer.MAX_VALUE;

        // Traverse the array to find the maximum and minimum element
        for (int i = 0; i < nums.length; i++) {
            max = Math.max(max, nums[i]);
            min = Math.min(min, nums[i]);
        }

        // Maximum possible value is k times the difference
        // between the largest and smallest element
        return (long) k * (max - min);
    }
}
